TELEGRAM_TOKEN=your_telegram_bot_token
GROQ_API_KEY=your_groq_api_key

# PostgreSQL (Railway подставляет DATABASE_URL при линковке PostgreSQL-сервиса)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Telegram chat_id администратора для команды /stats
ADMIN_CHAT_ID=123456789

# Опционально — путь к базе знаний для бота (по умолчанию company_data.txt рядом с bot.py)
# COMPANY_DATA_FILE=company_data.txt

# Опционально — только для scraper.py
# SCRAPER_OUTPUT=company_data.txt
# SCRAPER_DELAY=1
